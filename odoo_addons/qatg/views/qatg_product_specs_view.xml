<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="qatg_product_specs_list_view" model="ir.ui.view">
        <field name="name">qatg.product.specs.list</field>
        <field name="model">qatg.product.specs</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="unit"/>
                <field name="value_type"/>
            </list>
        </field>
    </record>

    <record id="qatg_product_specs_form_view" model="ir.ui.view">
        <field name="name">qatg.product.specs.form</field>
        <field name="model">qatg.product.specs</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="unit"/>
                        <field name="value_type"/>
                    </group>
                    <notebook>
                        <page string="Values">
                            <field name="specs_value_ids">
                                <list>
                                    <field name="product_id"/>
                                    <field name="value"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_qatg_product_specs" model="ir.actions.act_window">
        <field name="name">Specs</field>
        <field name="res_model">qatg.product.specs</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="qatg_product_specs_menu"
        name="Specs"
        parent="qatg_menu"
        action="action_qatg_product_specs"/>

</odoo>