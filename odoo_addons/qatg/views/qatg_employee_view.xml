<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="qatg_employee_form_view" model="ir.ui.view">
        <field name="name">qatg.employee.form.view</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- thêm tab vào notebook -->
            <xpath expr="//page[@name='hr_settings']" position="after">

                <page string="QATG Information">

                    <group>
                        <field name="social_security"/>
                        <field name="employee_type_selection"/>
                    </group>

                </page>
            </xpath>
        </field>
    </record>
    
    <record id="qatg_employee_list_view" model="ir.ui.view">
        <field name="name">qatg.employee.list.view</field>
        <field name="model">hr.employee</field>
    
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="job_title"/>
                <field name="work_email"/>
                <field name="social_security"/>
                <field name="employee_type_selection"/>
            </list>
        </field>
    </record>

    <record id="action_qatg_employee" model="ir.actions.act_window">
    
        <field name="name">Employee</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">list,form</field>
    
    </record>
    
    <record id="action_qatg_employee_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="qatg_employee_list_view"/>
        <field name="act_window_id" ref="action_qatg_employee"/>
    </record>
    
    <record id="action_qatg_employee_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="qatg_employee_form_view"/>
        <field name="act_window_id" ref="action_qatg_employee"/>
    </record>

    <menuitem
        id="qatg_menu"
        name="QATG"
        sequence="1"/>

    <menuitem
        id="qatg_employee_menu"
        name="Employee"
        parent="qatg_menu"
        action="action_qatg_employee"/>

</odoo>